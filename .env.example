JWT_SECRET=change-me-generate-with-openssl-rand-base64-32
POSTGRES_PASSWORD=change-me-use-a-strong-password

# Only used by docker-compose.prod.yml (HTTPS via Caddy).
# Leave DOMAIN unset/localhost to test HTTPS locally with Caddy's internal CA.
# Set DOMAIN to a real public hostname to get a Let's Encrypt certificate automatically.
DOMAIN=localhost
ACME_EMAIL=admin@example.com
